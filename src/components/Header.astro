---
import type { SiteConfig } from '../config/sites';
import { getSiteHomePath, getSiteNavLinks } from '../config/siteNav';

interface Props {
	site: SiteConfig;
	variant?: 'default' | 'compact';
}

const { site, variant = 'default' } = Astro.props;
const hasPrimaryCta = site.status !== 'future' && 'primaryCta' in site && 'primaryCtaHref' in site;
const homeHref = getSiteHomePath(site.key);
const siteNavLinks = getSiteNavLinks(site.key);
const menuId = `site-nav-menu-${site.key}`;

const navLink =
	site.key === 'outdoorKitchen'
		? { href: '/outdoor-kitchen-cost-melbourne-sydney/', label: 'Cost Guide' }
		: site.key === 'decking'
			? { href: '/decking-cost-melbourne/', label: 'Cost Guide' }
			: { href: '/paving-cost-melbourne', label: 'Cost Guide' };
---

<header class:list={['site-header', variant === 'compact' && 'site-header--compact']} role="banner">
	<div class="site-header__inner">
		<a class="site-header__brand" href={homeHref}>{site.name}</a>
		<div class="site-header__end">
			{
				variant === 'default' && siteNavLinks ? (
					<div class="site-header__menu">
						<button
							type="button"
							class="site-header__menu-toggle"
							aria-expanded="false"
							aria-controls={menuId}
							aria-label="Open site menu"
						>
							<span class="site-header__menu-icon" aria-hidden="true">
								<span />
								<span />
								<span />
							</span>
							<span class="site-header__menu-label">Menu</span>
						</button>
						<nav class="site-header__menu-panel" id={menuId} aria-label="Site sections" hidden>
							<ul class="site-header__menu-list">
								<li>
									<a class="site-header__menu-link site-header__menu-link--home" href={homeHref}>
										{site.name} home
									</a>
								</li>
								{
									siteNavLinks.map((link) => (
										<li>
											<a class="site-header__menu-link" href={link.href}>
												{link.label}
											</a>
										</li>
									))
								}
							</ul>
						</nav>
					</div>
				) : variant === 'default' ? (
					<nav class="site-header__nav" aria-label="Site">
						<a class="site-header__nav-link" href={navLink.href}>{navLink.label}</a>
					</nav>
				) : null
			}
			{
				hasPrimaryCta && variant === 'default' ? (
					<a class="site-header__cta" href={site.primaryCtaHref}>
						{site.primaryCta}
					</a>
				) : null
			}
		</div>
	</div>
</header>

<script>
	function initSiteHeaderMenus() {
		document.querySelectorAll('.site-header__menu').forEach((menuRoot) => {
			if (menuRoot.getAttribute('data-menu-ready') === 'true') return;
			menuRoot.setAttribute('data-menu-ready', 'true');

			const toggle = menuRoot.querySelector('.site-header__menu-toggle');
			const panel = menuRoot.querySelector('.site-header__menu-panel');
			const label = toggle?.querySelector('.site-header__menu-label');
			if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

			const closeMenu = () => {
				panel.hidden = true;
				menuRoot.classList.remove('is-open');
				toggle.setAttribute('aria-expanded', 'false');
				toggle.setAttribute('aria-label', 'Open site menu');
				if (label) label.textContent = 'Menu';
			};

			const openMenu = () => {
				panel.hidden = false;
				menuRoot.classList.add('is-open');
				toggle.setAttribute('aria-expanded', 'true');
				toggle.setAttribute('aria-label', 'Close site menu');
				if (label) label.textContent = 'Close';
			};

			toggle.addEventListener('click', () => {
				const isOpen = toggle.getAttribute('aria-expanded') === 'true';
				if (isOpen) {
					closeMenu();
				} else {
					openMenu();
				}
			});

			panel.querySelectorAll('a').forEach((link) => {
				link.addEventListener('click', closeMenu);
			});

			document.addEventListener('click', (event) => {
				if (!menuRoot.contains(event.target as Node)) {
					closeMenu();
				}
			});

			document.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') {
					closeMenu();
				}
			});
		});
	}

	initSiteHeaderMenus();
	document.addEventListener('astro:page-load', initSiteHeaderMenus);
</script>

<style>
	.site-header {
		position: relative;
		z-index: 30;
		padding: 0.75rem clamp(1.25rem, 4vw, 2rem);
		background-color: var(--color-white);
		border-bottom: 1px solid var(--color-border);
	}

	.site-header--compact {
		padding-top: 0.5rem;
		padding-bottom: 0.5rem;
	}

	.site-header__inner {
		max-width: 72rem;
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.site-header__end {
		display: flex;
		align-items: center;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.site-header__nav {
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.site-header__nav-link {
		font-size: 0.875rem;
		font-weight: 600;
		color: color-mix(in srgb, var(--color-text) 82%, var(--color-background));
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 45%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.site-header__nav-link:hover {
		color: var(--color-primary-dark);
		border-bottom-color: var(--color-primary);
	}

	.site-header__nav-link:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.site-header__menu {
		position: relative;
	}

	.site-header__menu-toggle {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.45rem 0.75rem;
		font: inherit;
		font-size: 0.875rem;
		font-weight: 600;
		color: color-mix(in srgb, var(--color-text) 82%, var(--color-background));
		background-color: var(--color-white);
		border: 1px solid var(--color-border);
		border-radius: 6px;
		cursor: pointer;
		transition:
			border-color 0.15s ease,
			color 0.15s ease,
			background-color 0.15s ease;
	}

	.site-header__menu-toggle:hover {
		color: var(--color-primary-dark);
		border-color: color-mix(in srgb, var(--color-primary) 55%, var(--color-border));
	}

	.site-header__menu-toggle:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
	}

	.site-header__menu-toggle[aria-expanded='true'] {
		color: var(--color-primary-dark);
		border-color: var(--color-primary);
		background-color: color-mix(in srgb, var(--color-accent) 45%, var(--color-white));
	}

	.site-header__menu-icon {
		display: inline-flex;
		flex-direction: column;
		justify-content: center;
		gap: 3px;
		width: 1rem;
		height: 1rem;
	}

	.site-header__menu-icon span {
		display: block;
		height: 2px;
		border-radius: 1px;
		background-color: currentColor;
	}

	.site-header__menu-label {
		line-height: 1;
	}

	.site-header__menu-panel {
		position: absolute;
		top: calc(100% + 0.45rem);
		right: 0;
		z-index: 20;
		min-width: min(18rem, calc(100vw - 2.5rem));
		padding: 0.5rem;
		background-color: var(--color-white);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		box-shadow: 0 10px 28px color-mix(in srgb, var(--color-text) 12%, transparent);
	}

	.site-header__menu-panel[hidden] {
		display: none;
	}

	.site-header__menu-list {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.site-header__menu-link {
		display: block;
		padding: 0.65rem 0.75rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: color-mix(in srgb, var(--color-text) 82%, var(--color-background));
		text-decoration: none;
		border-radius: 6px;
		transition:
			background-color 0.15s ease,
			color 0.15s ease;
	}

	.site-header__menu-link:hover {
		color: var(--color-primary-dark);
		background-color: color-mix(in srgb, var(--color-accent) 55%, var(--color-white));
	}

	.site-header__menu-link:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 2px;
	}

	.site-header__menu-link--home {
		border-bottom: 1px solid var(--color-border);
		margin-bottom: 0.25rem;
		border-radius: 6px 6px 0 0;
	}

	.site-header__brand {
		font-size: 1rem;
		font-weight: 650;
		color: var(--color-text);
		text-decoration: none;
		letter-spacing: -0.02em;
	}

	.site-header__brand:hover {
		color: var(--color-primary-dark);
	}

	.site-header__brand:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 4px;
	}

	.site-header__cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		white-space: nowrap;
		border-radius: 6px;
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		border: 1px solid var(--color-primary-dark);
		transition:
			background-color 0.15s ease,
			border-color 0.15s ease;
	}

	.site-header__cta:hover {
		background-color: var(--color-primary);
		border-color: var(--color-primary);
	}

	.site-header__cta:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
	}

	@media (max-width: 640px) {
		.site-header {
			padding: 0.875rem 1rem;
		}

		.site-header__inner {
			gap: 0.85rem;
		}

		.site-header__end {
			width: 100%;
			justify-content: space-between;
			gap: 0.75rem;
		}

		.site-header__menu {
			position: static;
		}

		.site-header__menu.is-open {
			flex: 1 0 100%;
		}

		.site-header__menu-toggle {
			min-height: 2.75rem;
			padding: 0.65rem 0.875rem;
			font-size: 0.9375rem;
		}

		.site-header__cta {
			flex: 1 1 auto;
			min-height: 2.75rem;
			padding-inline: 0.85rem;
			text-align: center;
		}

		.site-header__menu-panel {
			position: static;
			width: 100%;
			min-width: 0;
			max-height: calc(100dvh - 8rem);
			margin-top: 0.75rem;
			padding: 0.35rem;
			border-radius: 12px;
			box-shadow: 0 18px 48px rgb(23 25 26 / 18%);
			overflow-y: auto;
		}

		.site-header__menu-link {
			padding: 0.9rem 0.95rem;
			font-size: 0.96875rem;
			line-height: 1.25;
		}

		.site-header__menu-link--home {
			margin-bottom: 0.15rem;
		}
	}
</style>
