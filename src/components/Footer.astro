---
import type { SiteConfig } from '../config/sites';

interface Props {
	site: SiteConfig;
	/** Extra inline links after the main website link (e.g. “Paving guide home”). */
	extraLinks?: { href: string; label: string }[];
	/** Hide the sitewide “Paving Cost Melbourne” link (e.g. on that page). */
	hidePavingCostMelbourneLink?: boolean;
	/** Hide the sitewide “Driveway Paving Melbourne” link (e.g. on that page). */
	hideDrivewayPavingMelbourneLink?: boolean;
}

const { site, extraLinks = [], hidePavingCostMelbourneLink = false, hideDrivewayPavingMelbourneLink = false } =
	Astro.props;
const mainUrl = site.status !== 'future' && 'mainWebsiteUrl' in site ? site.mainWebsiteUrl : null;
---

<footer class="site-footer">
	<p class="site-footer__brand">{site.brandLine}</p>
	<p class="site-footer__links">
		{mainUrl ? <a class="site-footer__link" href={mainUrl}>Visit main website</a> : null}
		{
			hidePavingCostMelbourneLink ? null : (
				<span class="site-footer__link-cluster">
					{mainUrl ? <span class="site-footer__sep" aria-hidden="true"> · </span> : null}
					<a class="site-footer__link" href="/paving-cost-melbourne">Paving Cost Melbourne</a>
				</span>
			)
		}
		{
			hideDrivewayPavingMelbourneLink ? null : (
				<span class="site-footer__link-cluster">
					{mainUrl || !hidePavingCostMelbourneLink ? <span class="site-footer__sep" aria-hidden="true"> · </span> : null}
					<a class="site-footer__link" href="/driveway-paving-melbourne">Driveway Paving Melbourne</a>
				</span>
			)
		}
		<span class="site-footer__link-cluster">
			{
				mainUrl || !hidePavingCostMelbourneLink || !hideDrivewayPavingMelbourneLink ? (
					<span class="site-footer__sep" aria-hidden="true"> · </span>
				) : null
			}
			<a class="site-footer__link" href="/wet-bed-vs-concrete-base-paving">Wet Bed vs Concrete Base</a>
		</span>
		{
			extraLinks.map((link) => (
				<span class="site-footer__link-cluster">
					<span class="site-footer__sep" aria-hidden="true"> · </span>
					<a class="site-footer__link" href={link.href}>
						{link.label}
					</a>
				</span>
			))
		}
	</p>
</footer>

<style>
	.site-footer {
		padding: 2rem clamp(1.25rem, 5vw, 3rem) 2.5rem;
		text-align: center;
		background-color: var(--color-background);
		border-top: 1px solid var(--color-border);
	}

	.site-footer__brand {
		margin: 0 0 0.75rem;
		font-size: 0.875rem;
		color: color-mix(in srgb, var(--color-text) 58%, var(--color-background));
	}

	.site-footer__links {
		margin: 0;
		font-size: 0.875rem;
	}

	.site-footer__sep {
		color: color-mix(in srgb, var(--color-text) 45%, var(--color-background));
	}

	.site-footer__link {
		font-size: 0.875rem;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
		text-decoration: underline;
		text-underline-offset: 3px;
	}

	.site-footer__link:hover {
		color: var(--color-primary-dark);
	}

	.site-footer__link:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}
</style>
