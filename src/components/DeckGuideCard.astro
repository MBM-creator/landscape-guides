---
import type { DeckGuideCard } from '../content/decking/guides';

interface Props {
	guide: DeckGuideCard;
}

const { guide } = Astro.props;
---

<li class="card">
	<div class="card__media">
		<img class="card__img" src={guide.image} alt={guide.alt} loading="lazy" />
	</div>
	<h3 class="card__title">{guide.title}</h3>
	<p class="card__text">{guide.description}</p>
	<a class="card__cta" href={guide.href}>Read guide →</a>
</li>

<style>
	.card {
		background: var(--color-white);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		overflow: hidden;
		display: flex;
		flex-direction: column;
	}

	.card__media {
		aspect-ratio: 4 / 3;
		overflow: hidden;
		background-color: var(--color-accent);
	}

	.card__img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.card__title {
		margin: 0;
		padding: 1rem 1.125rem 0.25rem;
		font-size: 1.0625rem;
		font-weight: 650;
		color: var(--color-text);
	}

	.card__text {
		margin: 0;
		padding: 0 1.125rem 1rem;
		font-size: 0.9375rem;
		color: color-mix(in srgb, var(--color-text) 74%, var(--color-background));
		line-height: 1.55;
		flex-grow: 1;
	}

	.card__cta {
		margin: 0 1.125rem 1.125rem;
		font-size: 0.875rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		align-self: flex-start;
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.card__cta:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.card__cta:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}
</style>
