---
import PavingStylePage from '../templates/PavingStylePage.astro';
import { herringbonePavingMelbournePage } from '../content/paving/pages/herringbone';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(herringbonePavingMelbournePage.canonical, `https://${site.domain}`).href;
---

<PavingStylePage site={site} canonical={canonical} content={herringbonePavingMelbournePage} />
