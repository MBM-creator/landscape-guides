---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import { sites } from '../config/sites';

const site = sites.decking;

/** Canonical lives on the public deck domain, never the build host. */
const canonical = `https://${site.domain}/decking-cost-melbourne/`;

const title = 'Decking Cost Melbourne | Deck Cost Guide';
const description =
	'What a new deck costs in Melbourne — broad price bands, the structure and site factors that move the number, and how to compare deck quotes fairly.';
---

<BaseLayout title={title} description={description} site={site} canonical={canonical}>
	<Header site={site} />
	<div class="page">
		<header class="hero" id="top">
			<div class="hero__inner">
				<p class="hero__eyebrow">Deck cost planning · Melbourne</p>
				<h1 class="hero__title">Decking cost in Melbourne</h1>
				<p class="hero__sub">
					A new deck rarely comes down to a clean per-square-metre rate. Height off the ground, footings, framing and access usually move the number more than the
					board you choose. Below is what to plan around before you compare quotes.
				</p>
				<div class="hero__actions">
					<a class="btn btn--primary" href={site.primaryCtaHref}>{site.primaryCta}</a>
					<a class="hero__secondary" href="/">Back to the Deck Cost Guide</a>
				</div>
			</div>
		</header>

		<section class="section" aria-labelledby="ranges-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="ranges-heading" class="section__title">Broad cost bands to plan around</h2>
				<p class="section__lead section__lead--tight">
					Treat these as planning ranges, not quotes — firm pricing needs a site visit, ground check and final material choice.
				</p>
				<ul class="factors">
					<li>
						<strong>Low-set treated pine deck</strong>
						<span>Close to the ground, simple shape and a budget board — often the lowest band per square metre, before stairs or balustrade.</span>
					</li>
					<li>
						<strong>Hardwood or composite deck</strong>
						<span>Mid-range boards, more framing and fixings, and a tidier finish push the rate up noticeably over treated pine.</span>
					</li>
					<li>
						<strong>Elevated or structural deck</strong>
						<span>Height off the ground means deeper footings, posts, bracing, balustrade and often a permit — usually the most expensive band.</span>
					</li>
				</ul>
			</div>
		</section>

		<CTASection
			sectionId="contact"
			headingId="cta-heading"
			bridge="Structure and site access set the price before boards are chosen."
			title="Want a deck quote that matches your site?"
			description="Speak with Made By Mobbs Landscapes about deck structure, materials and how it connects to the rest of the backyard."
			ctaHref={site.primaryCtaHref}
			ctaLabel={site.primaryCta}
		/>
	</div>
	<Footer site={site} extraLinks={[{ href: '/', label: 'Deck Cost Guide home' }]} />
</BaseLayout>

<style>
	.page {
		overflow-x: clip;
	}

	.hero {
		padding: clamp(1.6rem, 4.5vw, 3rem) clamp(1.25rem, 5vw, 3rem) clamp(1.35rem, 3.5vw, 2.35rem);
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
		border-bottom: 1px solid var(--color-border);
	}

	.hero__inner {
		max-width: 40rem;
		margin: 0 auto;
		text-align: center;
	}

	.hero__eyebrow {
		margin: 0 0 0.45rem;
		font-size: 0.8125rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-text) 58%, var(--color-background));
	}

	.hero__title {
		margin: 0 0 0.55rem;
		font-size: clamp(1.875rem, 5vw, 2.75rem);
		font-weight: 650;
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.hero__sub {
		margin: 0 0 1.1rem;
		font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.hero__secondary {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.hero__secondary:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.hero__secondary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.875rem 1.5rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 6px;
		border: 1px solid transparent;
		transition:
			background-color 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.btn--primary {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		border-color: var(--color-primary-dark);
	}

	.btn--primary:hover {
		background-color: var(--color-primary);
		border-color: var(--color-primary);
	}

	.btn--primary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
	}

	.section {
		padding: clamp(2.75rem, 7vw, 4.5rem) clamp(1.25rem, 5vw, 3rem);
		background-color: var(--color-background);
	}

	.section__inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	.section__inner--narrow {
		max-width: 38rem;
	}

	.section__title {
		margin: 0 0 0.75rem;
		font-size: clamp(1.5rem, 3.5vw, 1.875rem);
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.section__lead {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
		line-height: 1.55;
		max-width: 36rem;
	}

	.section__lead--tight {
		margin-bottom: 1.25rem;
	}

	.factors {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.factors li {
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.factors li:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.factors strong {
		font-size: 1rem;
		color: var(--color-text);
	}

	.factors span {
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
		line-height: 1.55;
	}
</style>
