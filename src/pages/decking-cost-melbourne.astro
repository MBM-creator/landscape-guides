---
import DeckGuidePage from '../templates/DeckGuidePage.astro';
import { deckCostMelbournePage } from '../content/decking/pages/cost';
import { sites } from '../config/sites';

const site = sites.decking;
const canonical = new URL(deckCostMelbournePage.canonical, `https://${site.domain}`).href;
---

<DeckGuidePage site={site} canonical={canonical} content={deckCostMelbournePage} />
