---
import OutdoorKitchenGuidePage from '../templates/OutdoorKitchenGuidePage.astro';
import { outdoorKitchenDesignPage } from '../content/outdoorKitchen/pages/design';
import { sites } from '../config/sites';

const site = sites.outdoorKitchen;
const canonical = new URL(outdoorKitchenDesignPage.canonical, `https://${site.domain}`).href;
---

<OutdoorKitchenGuidePage site={site} canonical={canonical} content={outdoorKitchenDesignPage} />
