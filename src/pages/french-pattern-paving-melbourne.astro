---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import RelatedPavingGuides from '../components/RelatedPavingGuides.astro';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(Astro.url.pathname, `https://${site.domain}`).href;

const title = 'French Pattern Paving Melbourne | Costs, Patterns & Design Guide';
const description =
	"Learn what French pattern paving is, where it works best, typical Melbourne costs, common mistakes and how to estimate your project using our paving cost calculator.";

const bookUrl = '#';
const calculatorFrenchUrl = '/paving-cost-calculator?style=french-pattern';

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Is French pattern paving expensive?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'It usually costs more per square metre than straightforward single-size paving because of layout, cutting and the care needed to keep repeats true. Stone grade, thickness and site access move the figure substantially\u2014the calculator on this site is the sensible first step before a fixed quote.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is French pattern paving good around pools?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'It can work very well around pools when module size, slip resistance, falls and coping junctions are chosen for wet use and your certifier\u2019s requirements. The pattern itself does not replace those technical decisions.',
			},
		},
		{
			'@type': 'Question',
			name: 'What stone is best for French pattern paving?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Travertine and limestone modular packs are the most common in Melbourne because they suit the scale of residential repeats and soften visually. The \u201Cbest\u201D answer still follows from exposure, cleaning expectations, pool rules if relevant, and the architecture you are pairing with.',
			},
		},
		{
			'@type': 'Question',
			name: 'Does French pattern paving date?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Modular natural stone has been used for centuries; what dates a project is usually poor detailing or a fad colour rather than the pattern. Neutral stone, disciplined joints and correct falls tend to age calmly.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is French pattern paving hard to lay?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'For an experienced paving team it is routine; for a first-time DIYer it is demanding because small set-out errors compound across the field. Most homeowners engage specialists once they understand the cutting and alignment time involved.',
			},
		},
	],
};
---

<BaseLayout title={title} description={description} site={site} canonical={canonical}>
	<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
	<Header site={site} />
	<div class="page">
		<header class="hero" id="top">
			<div class="hero__inner">
				<p class="hero__eyebrow">Paving style guide</p>
				<h1 class="hero__title">French Pattern Paving Melbourne</h1>
				<p class="hero__sub">
					French pattern paving uses multiple stone sizes laid in a repeating modular layout. It creates a timeless, structured look that
					suits entertaining areas, pool surrounds and larger paved spaces across Melbourne homes.
				</p>
				<div class="hero__actions">
					<a class="btn btn--primary" href={calculatorFrenchUrl}>Estimate French Pattern Paving Cost</a>
					<a class="hero__secondary" href="/">Back to Paving Guide</a>
				</div>
			</div>
		</header>

		<section class="media-section" aria-label="French pattern travertine paving example">
			<div class="media-section__inner">
				<img
					class="media-section__img"
					src="/images/french-pattern.webp"
					alt="French pattern travertine paving in Melbourne backyard entertaining area"
					width="1151"
					height="1200"
					loading="eager"
					decoding="async"
					fetchpriority="high"
				/>
			</div>
		</section>

		<section class="section" aria-labelledby="what-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="what-heading" class="section__title">What is French pattern paving?</h2>
				<p class="section__lead section__lead--tight">
					French pattern paving (sometimes called Versailles or modular pattern) arranges tiles in a fixed repeat of several sizes. The
					layout reads orderly from a distance, but the mix of lengths and widths breaks up the rigidity of a single-size grid—something
					homeowners often notice when comparing <strong>French pattern outdoor tiles</strong> with stretcher-bond paving.
				</p>
				<p class="section__lead section__lead--tight">
					It is more complex to set out than simple stretcher bond: each repeat must align, joint lines need to stay readable and stone
					variation has to be balanced across the field. <strong>French pattern travertine in Melbourne</strong> and limestone are common
					choices because their tonal variation suits the pattern; denser granites can work where the brief calls for a crisper look.
				</p>
				<ul class="bullets">
					<li>A repeating modular layout built from several standard tile sizes, not one repeated rectangle</li>
					<li>Multiple tile sizes per repeat, which helps scale the pattern across large areas without visual monotony</li>
					<li>A structured surface that still feels natural when paired with the right stone and joint colour</li>
					<li>Often supplied as <strong>French pattern pavers</strong> in travertine or limestone, with packs sized to complete full repeats</li>
					<li>More cutting, dry-lay thinking and layout time than uniform pavers, which feeds into <strong>French pattern paving cost in Melbourne</strong></li>
				</ul>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="where-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="where-heading" class="section__title">Where French pattern paving works best</h2>
				<p class="section__lead section__lead--tight">
					The pattern needs enough area to show several full repeats; tiny landings rarely do it justice. Where there is room, it carries
					<strong>French pattern paving around pools</strong>, alfresco slabs and garden connections with equal confidence—as long as stone
					choice, slip resistance and falls suit each use.
				</p>
				<ul class="bullets">
					<li>Pool surrounds, when drainage, coping lines and wet-area slip ratings are resolved with the pool fence and certifier in mind</li>
					<li>Entertaining areas and outdoor dining where the modular field can align with furniture groupings without feeling grid-locked</li>
					<li>Courtyards that benefit from a single, legible paving language across the whole floor plane</li>
					<li>Larger patios and terrace slabs where the repeat can run without constant small cuts at the perimeter</li>
					<li>Mediterranean-influenced and contemporary Melbourne homes where modular stone sits comfortably beside rendered walls, steel and planting</li>
				</ul>
			</div>
		</section>

		<section class="section" aria-labelledby="cost-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="cost-heading" class="section__title">What affects French pattern paving cost?</h2>
				<p class="section__lead section__lead--tight">
					<strong>French pattern paving cost in Melbourne</strong> is driven by how much stone, bedding and skilled setting your site needs,
					not headline square metres alone. Use our <a class="hero__secondary" href="/paving-cost-calculator">paving cost calculator</a> for a
					guide range, then refine with a site visit once access, levels and finishes are clear.
				</p>
				<p class="compare-link-wrap">
					<a class="hero__secondary" href="/crazy-paving-vs-french-pattern">Compare crazy paving vs French pattern</a>
				</p>
				<ul class="factors">
					<li>
						<strong>Area in m²</strong>
						<span>Overall size sets material quantities; perimeter length and shape often dictate cuts, borders and how many pattern repeats fit cleanly.</span>
					</li>
					<li>
						<strong>Stone type and thickness</strong>
						<span>Supply price, handling weight and structural suitability (foot traffic, furniture, occasional vehicle) follow directly from the product and its thickness.</span>
					</li>
					<li>
						<strong>Pattern complexity</strong>
						<span>French pattern is inherently more involved than a single-size layout; tight modules, feature bands or direction changes add setting-out time.</span>
					</li>
					<li>
						<strong>Number of cuts and borders</strong>
						<span>Steps, curved edges, pool rebates and soldier courses multiply cuts and slow the lay compared with a simple rectangle.</span>
					</li>
					<li>
						<strong>Base preparation</strong>
						<span>Excavation depth, sub-grade treatment and compaction underpin long-term stability—particularly where existing paving or fill has to be removed.</span>
					</li>
					<li>
						<strong>Drainage and fall</strong>
						<span>Surface water must sheet away from structures and pool shells; poor falls show up as ponding, efflorescence and premature wear at low spots.</span>
					</li>
					<li>
						<strong>Site access</strong>
						<span>Narrow side paths, stairs or long barrow runs add labour and can limit how materials are brought to the back garden.</span>
					</li>
				</ul>
				<p class="inline-cta">
					<a class="btn btn--primary btn--wide" href={calculatorFrenchUrl}>Estimate French Pattern Paving Cost</a>
				</p>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="pros-heading">
			<div class="section__inner">
				<h2 id="pros-heading" class="section__title section__title--centered">Pros and cons</h2>
				<p class="section__lead section__lead--centered">
					A straightforward checklist before you commit to modular stone across a large area of the garden.
				</p>
				<div class="split">
					<div class="split__col split__col--pros">
						<h3 class="split__heading">Pros</h3>
						<ul class="bullets bullets--tight">
							<li>Premium, timeless appearance that reads as considered rather than generic</li>
							<li>Visually softer than a plain grid of identical units, especially at pool and alfresco scale</li>
							<li>Suits natural stone packs sold for modular laying; grain and tone variation feel intentional</li>
							<li>Strong resale appeal when detailing, falls and materials are well resolved</li>
						</ul>
					</div>
					<div class="split__col split__col--cons">
						<h3 class="split__heading">Cons</h3>
						<ul class="bullets bullets--tight">
							<li>More cutting and layout time than uniform pavers, which affects programme and price</li>
							<li>Pattern mistakes and drift in joint alignment are visually obvious once you notice them</li>
							<li>Requires disciplined set-out from the first repeat—shortcuts telegraph across the whole field</li>
							<li>Material waste can be higher than single-size paving, depending on module and edge geometry</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="section" aria-labelledby="mistakes-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="mistakes-heading" class="section__title">Common mistakes</h2>
				<ul class="mistakes">
					<li>
						<strong>Inconsistent joint spacing</strong> — Joints that wander or tighten unevenly break the modular rhythm and trap organic debris.
					</li>
					<li>
						<strong>Poor set-out alignment</strong> — If early repeats are skewed, the pattern will not reconcile at boundaries, steps or pool coping.
					</li>
					<li>
						<strong>Mixing incompatible stone batches</strong> — Different calibres or tonal lots within one field read as patchy rather than natural variation.
					</li>
					<li>
						<strong>Poor drainage around pools</strong> — Water must leave the pavement and stay away from the shell and adjoining finishes; falls and grate positions need to work with the pattern.
					</li>
					<li>
						<strong>Choosing slippery finishes</strong> — Honed or filled surfaces around wet zones need to be checked against how the area will be used, including bare feet and winter mould.
					</li>
				</ul>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="mobbs-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="mobbs-heading" class="section__title">When to involve Made By Mobbs</h2>
				<p class="prose">
					Made By Mobbs Landscapes delivers complete outdoor spaces rather than isolated paving-only packages. French pattern work sits in the
					middle of levels, planting, drainage and how you move through the garden day to day.
				</p>
				<p class="prose">
					We are particularly useful when the modular field needs to meet lawn, garden beds or built planters cleanly—<strong>integration with planting</strong> and
					paving should feel like one design, not a hard surface dropped onto a plan. The same applies to <strong>levels and drainage</strong> where the
					pavement ties into existing thresholds, steps and rainwater paths.
				</p>
				<p class="prose">
					<strong>Coping and edging details</strong> around pools, and the <strong>relationship between paving and architecture</strong> (eaves lines, door
					heights, cladding joints), are where modular stone either looks bespoke or looks like an afterthought. We resolve those junctions before
					ordering stone.
				</p>
				<p class="prose">
					This page is guidance only: sensible questions and ballpark thinking before you commit. Firm pricing still depends on a proper look at
					access, services, existing structures and how you intend to use each zone.
				</p>
				<p class="inline-cta">
					<a class="btn btn--primary btn--wide" href={bookUrl}>Book a site visit with Made By Mobbs</a>
				</p>
			</div>
		</section>

		<section class="section faq" aria-labelledby="faq-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="faq-heading" class="section__title">Frequently asked questions</h2>
				<dl class="faq__list">
					<div class="faq__item">
						<dt class="faq__q">Is French pattern paving expensive?</dt>
						<dd class="faq__a">
							It usually costs more per square metre than straightforward single-size paving because of layout, cutting and the care needed to
							keep repeats true. Stone grade, thickness and site access move the figure substantially—the calculator on this site is the
							sensible first step before a fixed quote.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Is French pattern paving good around pools?</dt>
						<dd class="faq__a">
							It can work very well around pools when module size, slip resistance, falls and coping junctions are chosen for wet use and your
							certifier’s requirements. The pattern itself does not replace those technical decisions.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">What stone is best for French pattern paving?</dt>
						<dd class="faq__a">
							Travertine and limestone modular packs are the most common in Melbourne because they suit the scale of residential repeats and
							soften visually. The “best” answer still follows from exposure, cleaning expectations, pool rules if relevant, and the
							architecture you are pairing with.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Does French pattern paving date?</dt>
						<dd class="faq__a">
							Modular natural stone has been used for centuries; what dates a project is usually poor detailing or a fad colour rather than
							the pattern. Neutral stone, disciplined joints and correct falls tend to age calmly.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Is French pattern paving hard to lay?</dt>
						<dd class="faq__a">
							For an experienced paving team it is routine; for a first-time DIYer it is demanding because small set-out errors compound across
							the field. Most homeowners engage specialists once they understand the cutting and alignment time involved.
						</dd>
					</div>
				</dl>
			</div>
		</section>

		<RelatedPavingGuides excludeHref="/french-pattern-paving-melbourne" />

		<CTASection
			sectionId="estimate"
			headingId="final-cta-heading"
			title="Planning a French pattern paving project?"
			description="Start with a realistic guide price, then organise a site visit when you're ready to properly scope materials, levels and layout."
			ctaHref={calculatorFrenchUrl}
			ctaLabel="Estimate French Pattern Paving Cost"
		/>
	</div>
	<Footer site={site} extraLinks={[{ href: '/', label: 'Paving guide home' }]} />
</BaseLayout>

<style>
	.page {
		overflow-x: clip;
	}

	.hero {
		padding: clamp(2.5rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem) clamp(2.25rem, 6vw, 4rem);
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
		border-bottom: 1px solid var(--color-border);
	}

	.hero__inner {
		max-width: 40rem;
		margin: 0 auto;
		text-align: center;
	}

	.hero__eyebrow {
		margin: 0 0 0.75rem;
		font-size: 0.8125rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-text) 58%, var(--color-background));
	}

	.hero__title {
		margin: 0 0 1rem;
		font-size: clamp(1.875rem, 5vw, 2.75rem);
		font-weight: 650;
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.hero__sub {
		margin: 0 0 2rem;
		font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.hero__secondary {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.hero__secondary:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.hero__secondary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.875rem 1.5rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 6px;
		border: 1px solid transparent;
		transition:
			background-color 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.btn--primary {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		border-color: var(--color-primary-dark);
	}

	.btn--primary:hover {
		background-color: var(--color-primary);
		border-color: var(--color-primary);
	}

	.btn--primary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
	}

	.btn--wide {
		min-width: min(100%, 22rem);
		padding-left: 1.75rem;
		padding-right: 1.75rem;
	}

	.media-section {
		padding: 0 clamp(1.25rem, 5vw, 3rem) clamp(2.5rem, 7vw, 4rem);
		background-color: var(--color-background);
	}

	.media-section__inner {
		max-width: 56rem;
		margin: 0 auto;
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		background-color: var(--color-accent);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 6%, transparent);
	}

	.media-section__img {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}

	.section {
		padding: clamp(2.75rem, 7vw, 4.5rem) clamp(1.25rem, 5vw, 3rem);
		background-color: var(--color-background);
	}

	.section--alt {
		background-color: var(--color-white);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.section__inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	.section__inner--narrow {
		max-width: 38rem;
	}

	.section__title {
		margin: 0 0 0.75rem;
		font-size: clamp(1.5rem, 3.5vw, 1.875rem);
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.section__title--centered {
		text-align: center;
	}

	.section__lead {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
		line-height: 1.55;
		max-width: 36rem;
	}

	.section__lead--tight {
		margin-bottom: 1.25rem;
	}

	.compare-link-wrap {
		margin: -0.35rem 0 1.25rem;
	}

	.section__lead--centered {
		margin-left: auto;
		margin-right: auto;
		text-align: center;
	}

	.prose {
		margin: 0 0 1.25rem;
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
	}

	.prose:last-of-type {
		margin-bottom: 0;
	}

	.bullets {
		margin: 0;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		font-size: 1rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 82%, var(--color-background));
	}

	.bullets--tight {
		gap: 0.5rem;
		font-size: 0.96875rem;
	}

	.factors {
		list-style: none;
		margin: 0 0 1.75rem;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.factors li {
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.factors li:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.factors strong {
		font-size: 1rem;
		color: var(--color-text);
	}

	.factors span {
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
		line-height: 1.55;
	}

	.inline-cta {
		margin: 0;
		text-align: center;
	}

	.split {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(1.5rem, 4vw, 2.5rem);
		margin-top: 0.5rem;
	}

	@media (min-width: 40rem) {
		.split {
			grid-template-columns: 1fr 1fr;
			align-items: start;
		}
	}

	.split__col {
		background: var(--color-background);
		border: 1px solid var(--color-border);
		border-radius: 8px;
		padding: 1.25rem 1.35rem 1.35rem;
	}

	.section--alt .split__col {
		background: color-mix(in srgb, var(--color-accent) 35%, var(--color-white));
	}

	.split__heading {
		margin: 0 0 0.85rem;
		font-size: 1.125rem;
		font-weight: 650;
		color: var(--color-text);
	}

	.mistakes {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.mistakes li {
		padding-left: 1rem;
		border-left: 3px solid var(--color-accent);
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
		line-height: 1.55;
	}

	.mistakes strong {
		color: var(--color-text);
	}

	.faq__list {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.faq__item {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.faq__item:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.faq__q {
		margin: 0 0 0.5rem;
