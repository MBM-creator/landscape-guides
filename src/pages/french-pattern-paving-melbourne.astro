---
import PavingStylePage from '../templates/PavingStylePage.astro';
import { frenchPatternPavingMelbournePage } from '../content/paving/pages/french-pattern';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(frenchPatternPavingMelbournePage.canonical, `https://${site.domain}`).href;
---

<PavingStylePage site={site} canonical={canonical} content={frenchPatternPavingMelbournePage} />
