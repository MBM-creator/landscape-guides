		background-color: var(--color-white);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.section__inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	.section__inner--narrow {
		max-width: 38rem;
	}

	.section__inner--wide {
		max-width: 56rem;
	}

	.section__title {
		margin: 0 0 0.75rem;
		font-size: clamp(1.5rem, 3.5vw, 1.875rem);
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.section__title--centered {
		text-align: center;
		margin-left: auto;
		margin-right: auto;
		max-width: 44rem;
	}

	.section__lead {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
		line-height: 1.55;
		max-width: 36rem;
	}

	.section__lead--tight {
		margin-bottom: 1.25rem;
	}

