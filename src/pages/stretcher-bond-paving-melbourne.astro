---
import PavingStylePage from '../templates/PavingStylePage.astro';
import { stretcherBondPavingMelbournePage } from '../content/paving/pages/stretcher-bond';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(stretcherBondPavingMelbournePage.canonical, `https://${site.domain}`).href;
---

<PavingStylePage site={site} canonical={canonical} content={stretcherBondPavingMelbournePage} />
