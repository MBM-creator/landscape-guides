		border-radius: 8px;
		padding: 1.25rem 1.35rem 1.35rem;
	}

	.section--alt .split__col {
		background: color-mix(in srgb, var(--color-accent) 35%, var(--color-white));
	}

	.split__heading {
		margin: 0 0 0.85rem;
		font-size: 1.125rem;
		font-weight: 650;
		color: var(--color-text);
	}

	.mistakes {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.mistakes li {
		padding-left: 1rem;
		border-left: 3px solid var(--color-accent);
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
		line-height: 1.55;
	}

	.mistakes strong {
