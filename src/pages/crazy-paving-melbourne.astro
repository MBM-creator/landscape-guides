---
import PavingStylePage from '../templates/PavingStylePage.astro';
import { crazyPavingMelbournePage } from '../content/paving/pages/crazy-paving';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(crazyPavingMelbournePage.canonical, `https://${site.domain}`).href;
---

<PavingStylePage site={site} canonical={canonical} content={crazyPavingMelbournePage} />
