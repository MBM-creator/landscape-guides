		margin-left: auto;
		margin-right: auto;
		text-align: center;
	}

	.prose {
		margin: 0 0 1.25rem;
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
	}

	.prose:last-of-type {
		margin-bottom: 0;
	}

	.bullets {
		margin: 0;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		font-size: 1rem;
