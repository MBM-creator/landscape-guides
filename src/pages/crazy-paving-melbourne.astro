	}

	.hero__title {
		margin: 0 0 1rem;
		font-size: clamp(1.875rem, 5vw, 2.75rem);
		font-weight: 650;
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.hero__sub {
		margin: 0 0 2rem;
		font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.hero__secondary {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.hero__secondary:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.hero__secondary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		padding: 0.875rem 1.5rem;
		font-size: 1rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 6px;
		border: 1px solid transparent;
