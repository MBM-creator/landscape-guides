---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import RelatedPavingGuides from '../components/RelatedPavingGuides.astro';
import { getSiteByHost } from '../config/sites';

const site = getSiteByHost(Astro.url.hostname);
const canonical = new URL(Astro.url.pathname, `https://${site.domain}`).href;

const title = 'Crazy Paving Melbourne | Costs, Styles & Advice';
const description =
	'Learn what crazy paving costs in Melbourne, where it works best, and what affects pricing, base preparation, drainage and material choice.';

const bookUrl = '#';
const calculatorCrazyUrl = '/paving-cost-calculator?style=crazy';

const faqJsonLd = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: [
		{
			'@type': 'Question',
			name: 'Is crazy paving expensive?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'It is usually more per square metre than straightforward rectangular paving because of cutting, fitting and jointing time. Stone choice and site access move the figure a lot; the calculator gives a sensible guide range before a site-specific quote.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is crazy paving suitable around pools?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'It can be, when stone type, thickness, slip resistance and falls are selected for wet use and your pool certifier\u2019s requirements. Detail at the coping and drainage matters as much as the stone itself.',
			},
		},
		{
			'@type': 'Question',
			name: 'Does crazy paving need a concrete base?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Not every path needs a slab, but many Melbourne installations use a concrete base or wet bed where stability, vehicle load or ground movement is a concern. The right specification follows from use, soil and drainage\u2014not a one-size rule.',
			},
		},
		{
			'@type': 'Question',
			name: 'Is crazy paving slippery?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'Slip resistance depends on the stone, finish and whether the surface is wet. We can shortlist materials and treatments for steps, paths and areas that stay damp or see bare feet.',
			},
		},
		{
			'@type': 'Question',
			name: 'How long does crazy paving take to install?',
			acceptedAnswer: {
				'@type': 'Answer',
				text: 'A small garden path might take a few days on site; larger entertaining areas or complex edges take longer. Weather, access and how much existing paving or lawn needs removing also affect the programme\u2014something we clarify after a walk-through.',
			},
		},
	],
};
---

<BaseLayout title={title} description={description} site={site} canonical={canonical}>
	<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
	<Header site={site} />
	<div class="page">
		<header class="hero" id="top">
			<div class="hero__inner">
				<p class="hero__eyebrow">Paving Style Guide</p>
				<h1 class="hero__title">Crazy Paving Melbourne</h1>
				<p class="hero__sub">
					Crazy paving is one of the most distinctive ways to create a natural stone path, patio or entertaining area. It suits Melbourne
					homes where texture, movement and a less formal finish are part of the design.
				</p>
				<div class="hero__actions">
					<a class="btn btn--primary" href={calculatorCrazyUrl}>Estimate your crazy paving cost in minutes</a>
					<a class="hero__secondary" href="/">Back to Paving Guide</a>
				</div>
			</div>
		</header>

		<section class="media-section" aria-label="Porphy crazy paving driveway">
			<div class="media-section__inner">
				<img
					class="media-section__img"
					src="/images/porphy-crazy-paving-driveway.jpg"
					alt="Porphy crazy paving driveway"
					width="748"
					height="643"
					loading="eager"
					decoding="async"
				/>
			</div>
		</section>

		<section class="section" aria-labelledby="what-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="what-heading" class="section__title">What is crazy paving?</h2>
				<p class="section__lead section__lead--tight">
					Crazy paving uses irregular pieces of natural stone, fitted together to form an organic pattern rather than a strict grid. Each
					piece is handled and trimmed to suit its neighbours, which gives the finished surface real character—and takes more time than
					laying uniform rectangular pavers.
				</p>
				<ul class="bullets">
					<li>Irregular natural stone pieces, selected and trimmed to lock together</li>
					<li>An organic pattern with movement and variation across the surface</li>
					<li>More labour-intensive than standard rectangular paving</li>
					<li>Strong visual character that reads as natural and crafted rather than mass-produced</li>
				</ul>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="where-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="where-heading" class="section__title">Where crazy paving works best</h2>
				<p class="section__lead section__lead--tight">
					It shines where you want the paving to feel connected to the garden and architecture, not stamped out in repeating rows.
				</p>
				<ul class="bullets">
					<li>Garden paths that curve through planting or connect outdoor “rooms”</li>
					<li>Courtyards where a softer, less formal surface suits the scale of the space</li>
					<li>Pool surrounds, when stone type, thickness, slip resistance and falls are chosen for wet use</li>
					<li>Entertaining areas where an organic layout anchors seating and tables</li>
					<li>Feature zones near planting, where the stone can echo natural textures in the landscape</li>
				</ul>
			</div>
		</section>

		<section class="section" aria-labelledby="cost-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="cost-heading" class="section__title">What affects crazy paving cost?</h2>
				<p class="section__lead section__lead--tight">
					Quotes reflect how much stone, bedding and skilled laying time your site needs—not just the square metres on the plan. Our{' '}
					<a class="hero__secondary" href="/paving-cost-melbourne">Melbourne paving cost guide</a> walks through what usually moves those
					figures before you plug numbers into the calculator.
				</p>
				<p class="compare-link-wrap">
					<a class="hero__secondary" href="/crazy-paving-vs-french-pattern">Compare crazy paving vs French pattern</a>
				</p>
				<ul class="factors">
					<li>
						<strong>Size (m²)</strong>
						<span>Overall project size scales material volumes and laying time; perimeter length often drives cuts and edging.</span>
					</li>
					<li>
						<strong>Stone type and thickness</strong>
						<span>Supply cost, handling weight and suitability for foot traffic or vehicles all follow from the product you choose.</span>
					</li>
					<li>
						<strong>Base preparation</strong>
						<span>Excavation depth, compaction and what sits below the bedding layer determine long-term stability.</span>
					</li>
					<li>
						<strong>Wet bed or concrete base</strong>
						<span>The fixing method depends on use, soil and movement risk; structural areas often spec a concrete slab or wet bed.</span>
					</li>
					<li>
						<strong>Drainage and fall</strong>
						<span>Surface water must sheet away cleanly; poor falls show up as ponding, staining or premature wear.</span>
					</li>
					<li>
						<strong>Number of cuts and edges</strong>
						<span>Tight curves, steps and borders multiply trimming and jointing compared with a simple rectangle.</span>
					</li>
					<li>
						<strong>Site access</strong>
						<span>Narrow side paths, stairs or long barrow runs add labour and sometimes crane or machine constraints.</span>
					</li>
				</ul>
				<div class="cost-range" aria-labelledby="cost-range-heading">
					<h3 id="cost-range-heading" class="cost-range__title">Typical crazy paving cost range</h3>
					<p class="cost-range__text">
						Most crazy paving projects in Melbourne sit between $500–$700 per m², depending on size, stone type, base preparation and access.
					</p>
					<p class="cost-range__text cost-range__text--last">
						Use the calculator below to get a project-specific range.
					</p>
					<p class="inline-cta">
						<a class="btn btn--primary btn--wide" href={calculatorCrazyUrl}>Estimate your cost</a>
					</p>
				</div>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="pros-heading">
			<div class="section__inner">
				<h2 id="pros-heading" class="section__title section__title--centered">Pros and cons</h2>
				<p class="section__lead section__lead--centered">
					Useful for deciding whether the look and ongoing care match how you use the space.
				</p>
				<div class="split">
					<div class="split__col split__col--pros">
						<h3 class="split__heading">Pros</h3>
						<ul class="bullets bullets--tight">
							<li>Natural, premium appearance that ages well when detailed correctly</li>
							<li>Works beautifully with planting and softer landscape forms</li>
							<li>Can suit heritage façades and contemporary architecture alike</li>
							<li>Less rigid than standard paving; movement in the pattern hides minor irregularity</li>
						</ul>
					</div>
					<div class="split__col split__col--cons">
						<h3 class="split__heading">Cons</h3>
						<ul class="bullets bullets--tight">
							<li>More labour-intensive to lay and to adjust on site</li>
							<li>Quality depends heavily on set-out, joint width and consistent bedding</li>
							<li>Poor drainage or base preparation will eventually telegraph through the stone</li>
							<li>Not always the cheapest option when total scope is compared like-for-like</li>
						</ul>
					</div>
				</div>
			</div>
		</section>

		<section class="section" aria-labelledby="mistakes-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="mistakes-heading" class="section__title">Common mistakes</h2>
				<ul class="mistakes">
					<li>
						<strong>Choosing stone only by appearance</strong> — Slip rating, thickness and suitability for the location matter as much as
						colour.
					</li>
					<li>
						<strong>Inconsistent joints</strong> — Wide, wandering joints or uneven bedding read as rushed workmanship and trap debris.
					</li>
					<li>
						<strong>Poor base preparation</strong> — Skipping depth, compaction or specification leads to movement and cracked bedding.
					</li>
					<li>
						<strong>Ignoring falls and drainage</strong> — Water must leave the pavement and stay away from structures and adjoining finishes.
					</li>
					<li>
						<strong>Using the wrong finish around wet areas</strong> — Pool surrounds and splash zones need compatible stone, sealers and
						detail at coping and grate lines.
					</li>
				</ul>
			</div>
		</section>

		<section class="section section--alt" aria-labelledby="mobbs-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="mobbs-heading" class="section__title">When to involve Made By Mobbs</h2>
				<p class="prose">
					Made By Mobbs Landscapes designs and builds complete outdoor spaces—no need to employ individual trades in isolation.
				</p>
				<p class="prose">
					Crazy paving sits alongside planting, finished levels, drainage, lighting and the correct materials that set your finished project
					apart. Getting those relationships right is what makes the paving feel intentional rather than bolted on.
				</p>
				<p class="prose">
					This page is a guide only: sensible ranges and checklist thinking before you commit. Firm pricing always requires a proper review of
					access, existing surfaces, services and how you intend to use the area.
				</p>
				<p class="inline-cta">
					<a class="btn btn--primary btn--wide" href={bookUrl}>Book a site visit with Made By Mobbs</a>
				</p>
			</div>
		</section>

		<section class="section faq" aria-labelledby="faq-heading">
			<div class="section__inner section__inner--narrow">
				<h2 id="faq-heading" class="section__title">Frequently asked questions</h2>
				<dl class="faq__list">
					<div class="faq__item">
						<dt class="faq__q">Is crazy paving expensive?</dt>
						<dd class="faq__a">
							It is usually more per square metre than straightforward rectangular paving because of cutting, fitting and jointing time.
							Stone choice and site access move the figure a lot; the calculator gives a sensible guide range before a site-specific
							quote.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Is crazy paving suitable around pools?</dt>
						<dd class="faq__a">
							It can be, when stone type, thickness, slip resistance and falls are selected for wet use and your pool certifier’s
							requirements. Detail at the coping and drainage matters as much as the stone itself.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Does crazy paving need a concrete base?</dt>
						<dd class="faq__a">
							Not every path needs a slab, but many Melbourne installations use a concrete base or wet bed where stability, vehicle load
							or ground movement is a concern. The right specification follows from use, soil and drainage—not a one-size rule.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">Is crazy paving slippery?</dt>
						<dd class="faq__a">
							Slip resistance depends on the stone, finish and whether the surface is wet. We can shortlist materials and treatments for
							steps, paths and areas that stay damp or see bare feet.
						</dd>
					</div>
					<div class="faq__item">
						<dt class="faq__q">How long does crazy paving take to install?</dt>
						<dd class="faq__a">
							A small garden path might take a few days on site; larger entertaining areas or complex edges take longer. Weather, access
							and how much existing paving or lawn needs removing also affect the programme—something we clarify after a walk-through.
						</dd>
					</div>
				</dl>
			</div>
		</section>

		<RelatedPavingGuides excludeHref="/crazy-paving-melbourne" />

		<CTASection
			sectionId="estimate"
			headingId="final-cta-heading"
			title="Planning a crazy paving project?"
			description="Start with a guide price, then book a site visit when you're ready for a proper scope."
			ctaHref={calculatorCrazyUrl}
			ctaLabel="Estimate your crazy paving cost in minutes"
		/>
	</div>
	<Footer site={site} extraLinks={[{ href: '/', label: 'Paving guide home' }]} />
</BaseLayout>

<style>
	.page {
		overflow-x: clip;
	}

	.hero {
		padding: clamp(2.5rem, 8vw, 5rem) clamp(1.25rem, 5vw, 3rem) clamp(2.25rem, 6vw, 4rem);
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
		border-bottom: 1px solid var(--color-border);
	}

