		border-radius: 8px;
		background: color-mix(in srgb, var(--color-accent) 35%, var(--color-white));
		box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
	}

	.guide-card__title {
		margin: 0;
		font-size: 1.125rem;
		font-weight: 650;
		line-height: 1.3;
		letter-spacing: -0.015em;
		color: var(--color-text);
	}

	.guide-card__text {
		margin: 0;
		flex: 1 1 auto;
		font-size: 0.96875rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
	}

	.guide-card__cta {
		align-self: flex-start;
		margin-top: 0.15rem;
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.guide-card__cta:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.guide-card__cta:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.compare-wrap {
		margin-top: 0.35rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		border: 1px solid var(--color-border);
		border-radius: 10px;
		background-color: var(--color-white);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
	}

	.compare-table {
		width: 100%;
		min-width: 36rem;
		border-collapse: collapse;
		font-size: 0.9375rem;
		line-height: 1.5;
