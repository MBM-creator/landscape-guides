		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.compare-wrap {
		margin-top: 0.35rem;
		overflow-x: auto;
		-webkit-overflow-scrolling: touch;
		border: 1px solid var(--color-border);
		border-radius: 10px;
		background-color: var(--color-white);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 5%, transparent);
	}

