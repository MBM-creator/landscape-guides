---
import DeckGuidePage from '../templates/DeckGuidePage.astro';
import { poolDeckingCostPage } from '../content/decking/pages/pool-cost';
import { sites } from '../config/sites';

const site = sites.decking;
const canonical = new URL(poolDeckingCostPage.canonical, `https://${site.domain}`).href;
---

<DeckGuidePage site={site} canonical={canonical} content={poolDeckingCostPage} />
