---
import type { SiteConfig } from '../config/sites';
import type { DeckGuidePageContent } from '../content/decking/deckGuidePage.types';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CTASection from '../components/CTASection.astro';
import RelatedDeckGuides from '../components/RelatedDeckGuides.astro';
import { DECK_HOME_PATH } from '../config/micrositeRoutes';

interface Props {
	site: SiteConfig;
	canonical: string;
	content: DeckGuidePageContent;
}

const { site, canonical, content } = Astro.props;

function stripHtmlForJsonLd(html: string): string {
	return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim();
}

const faqJsonLd =
	content.faqs?.length ?
		{
			'@context': 'https://schema.org',
			'@type': 'FAQPage',
			mainEntity: content.faqs.map((f) => ({
				'@type': 'Question',
				name: f.question,
				acceptedAnswer: {
					'@type': 'Answer',
					text: f.answerJsonLd ?? stripHtmlForJsonLd(f.answer),
				},
			})),
		}
	: null;

const mobbs = content.mobbsSection;
const hasPrimaryCta = site.status !== 'future' && 'primaryCta' in site && 'primaryCtaHref' in site;

const heroImgAttrs = {
	width: content.heroImageWidth ?? 1200,
	height: content.heroImageHeight ?? 1200,
};
---

<BaseLayout title={content.metaTitle} description={content.metaDescription} site={site} canonical={canonical}>
	{faqJsonLd ? <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} /> : null}
	<Header site={site} />
	<div class="page">
		<header class="hero" id="top">
			<div class="hero__inner">
				<p class="hero__eyebrow">{content.eyebrow}</p>
				<h1 class="hero__title">{content.h1}</h1>
				<p class="hero__sub" set:html={content.intro} />
				<div class="hero__actions">
					{
						hasPrimaryCta ? (
							<a class="btn btn--primary" href={site.primaryCtaHref}>
								{site.primaryCta}
							</a>
						) : null
					}
					<a class="hero__secondary" href={content.secondaryLinkHref}>{content.secondaryLinkText}</a>
				</div>
			</div>
		</header>

		<section class="media-section media-section--compact" aria-label={content.heroAlt}>
			<div class="media-section__inner">
				<img
					class="media-section__img"
					src={content.heroImage}
					alt={content.heroAlt}
					{...heroImgAttrs}
					loading="eager"
					decoding="async"
				/>
			</div>
		</section>

		{
			content.sections.map((sec) => (
				<section class:list={['section', sec.variant === 'alt' && 'section--alt']} aria-labelledby={`${sec.id}-heading`}>
					<div class:list={['section__inner', 'section__inner--narrow']}>
						<h2 id={`${sec.id}-heading`} class="section__title">
							{sec.title}
						</h2>
						{
							sec.image ? (
								<img
									class="section__image"
									src={sec.image.src}
									alt={sec.image.alt}
									width={sec.image.width}
									height={sec.image.height}
									loading="lazy"
									decoding="async"
								/>
							) : null
						}
						{sec.leads?.map((html) => <p class="section__lead section__lead--tight" set:html={html} />)}
						{sec.bullets?.length ? (
							<ul class="bullets">
								{sec.bullets.map((item) => (
									<li set:html={item} />
								))}
							</ul>
						) : null}
						{sec.factors?.length ? (
							<ul class="factors">
								{sec.factors.map((row) => (
									<li>
										<strong>{row.label}</strong>
										<span set:html={row.detailHtml} />
									</li>
								))}
							</ul>
						) : null}
					</div>
				</section>
			))
		}

		{
			content.commonMistakes?.length ? (
				<section class="section section--mistakes" aria-labelledby="mistakes-heading">
					<div class="section__inner section__inner--narrow">
						<h2 id="mistakes-heading" class="section__title">
							{content.commonMistakesHeading ?? 'Common deck mistakes'}
						</h2>
						<ul class="mistakes">
							{content.commonMistakes.map((html) => (
								<li set:html={html} />
							))}
						</ul>
					</div>
				</section>
			) : null
		}

		<section class:list={['section', mobbs.variant === 'alt' && 'section--alt']} aria-labelledby={`${mobbs.id}-heading`}>
			<div class="section__inner section__inner--narrow">
				<h2 id={`${mobbs.id}-heading`} class="section__title">{mobbs.title}</h2>
				{mobbs.paragraphs.map((html) => (
					<p class="prose" set:html={html} />
				))}
				<p class="inline-cta">
					<a class="btn btn--primary btn--wide" href={mobbs.bookCta.href}>{mobbs.bookCta.label}</a>
				</p>
			</div>
		</section>

		{
			content.relatedGuides.mode === 'override' ? (
				<RelatedDeckGuides guidesOverride={content.relatedGuides.guides} />
			) : (
				<RelatedDeckGuides excludeHref={content.relatedGuides.excludeHref} />
			)
		}

		{
			content.faqs?.length ? (
				<section class="section faq" aria-labelledby="faq-heading">
					<div class="section__inner section__inner--narrow">
						<h2 id="faq-heading" class="section__title">Questions we hear on site</h2>
						<dl class="faq__list">
							{
								content.faqs.map((f) => (
									<div class="faq__item">
										<dt class="faq__q">{f.question}</dt>
										<dd class="faq__a" set:html={f.answer} />
									</div>
								))
							}
						</dl>
					</div>
				</section>
			) : null
		}

		<CTASection
			sectionId={content.finalCta.sectionId}
			headingId={content.finalCta.headingId}
			bridge={content.finalCta.bridge}
			title={content.finalCta.title}
			description={content.finalCta.description}
			ctaHref={content.finalCta.ctaHref}
			ctaLabel={content.finalCta.ctaLabel}
		/>
	</div>
	<Footer site={site} extraLinks={[{ href: DECK_HOME_PATH, label: 'Deck Cost Guide home' }]} />
</BaseLayout>

<style>
	.page {
		overflow-x: clip;
	}

	.hero {
		padding: clamp(1.6rem, 4.5vw, 3rem) clamp(1.25rem, 5vw, 3rem) clamp(1.35rem, 3.5vw, 2.35rem);
		background: linear-gradient(180deg, var(--color-white) 0%, var(--color-background) 100%);
		border-bottom: 1px solid var(--color-border);
	}

	.hero__inner {
		max-width: 40rem;
		margin: 0 auto;
		text-align: center;
	}

	.hero__eyebrow {
		margin: 0 0 0.45rem;
		font-size: 0.8125rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: color-mix(in srgb, var(--color-text) 58%, var(--color-background));
	}

	.hero__title {
		margin: 0 0 0.55rem;
		font-size: clamp(1.875rem, 5vw, 2.75rem);
		font-weight: 650;
		line-height: 1.15;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.hero__sub {
		margin: 0 0 1.1rem;
		font-size: clamp(1.0625rem, 2.5vw, 1.1875rem);
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
	}

	.hero__actions {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1rem;
	}

	.hero__secondary {
		font-size: 0.9375rem;
		font-weight: 600;
		color: var(--color-primary-dark);
		text-decoration: none;
		border-bottom: 1px solid color-mix(in srgb, var(--color-primary) 50%, transparent);
		transition:
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.hero__secondary:hover {
		color: var(--color-primary);
		border-bottom-color: var(--color-primary);
	}

	.hero__secondary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
		border-radius: 2px;
	}

	.btn {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		min-height: 2.75rem;
		padding: 0.5rem 1rem;
		font-size: 0.875rem;
		font-weight: 600;
		text-decoration: none;
		border-radius: 6px;
		border: 1px solid transparent;
		text-align: center;
		white-space: nowrap;
		transition:
			background-color 0.15s ease,
			color 0.15s ease,
			border-color 0.15s ease;
	}

	.btn--primary {
		background-color: var(--color-primary-dark);
		color: var(--color-white);
		border-color: var(--color-primary-dark);
	}

	.btn--primary:hover {
		background-color: var(--color-primary);
		border-color: var(--color-primary);
	}

	.btn--primary:focus-visible {
		outline: 2px solid var(--color-primary-dark);
		outline-offset: 3px;
	}

	.btn--wide {
		min-width: min(100%, 22rem);
	}

	@media (max-width: 640px) {
		.btn {
			width: 100%;
		}
	}

	.section {
		padding: clamp(2.75rem, 7vw, 4.5rem) clamp(1.25rem, 5vw, 3rem);
		background-color: var(--color-background);
	}

	.section--alt {
		background-color: var(--color-white);
		border-top: 1px solid var(--color-border);
		border-bottom: 1px solid var(--color-border);
	}

	.section--mistakes {
		background-color: color-mix(in srgb, var(--color-accent) 42%, var(--color-background));
	}

	.section__inner {
		max-width: 72rem;
		margin: 0 auto;
	}

	.section__inner--narrow {
		max-width: 38rem;
	}

	.section__title {
		margin: 0 0 0.75rem;
		font-size: clamp(1.5rem, 3.5vw, 1.875rem);
		font-weight: 650;
		letter-spacing: -0.02em;
		color: var(--color-text);
	}

	.section__lead {
		margin: 0 0 1.5rem;
		font-size: 1.0625rem;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
		line-height: 1.55;
		max-width: 36rem;
	}

	.section__lead--tight {
		margin-bottom: 1.25rem;
	}

	.section__image {
		display: block;
		width: 100%;
		height: auto;
		margin: 0 0 1.35rem;
		border-radius: 12px;
		box-shadow: 0 18px 44px rgb(23 25 26 / 10%);
	}

	.prose {
		margin: 0 0 1.25rem;
		font-size: 1.0625rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
	}

	.prose:last-of-type {
		margin-bottom: 0;
	}

	.bullets {
		margin: 0;
		padding-left: 1.25rem;
		display: flex;
		flex-direction: column;
		gap: 0.65rem;
		font-size: 1rem;
		line-height: 1.55;
		color: color-mix(in srgb, var(--color-text) 82%, var(--color-background));
	}

	.factors {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.25rem;
	}

	.factors li {
		padding-bottom: 1.25rem;
		border-bottom: 1px solid var(--color-border);
		display: flex;
		flex-direction: column;
		gap: 0.35rem;
	}

	.factors li:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.factors strong {
		font-size: 1rem;
		color: var(--color-text);
	}

	.factors span {
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 72%, var(--color-background));
		line-height: 1.55;
	}

	.inline-cta {
		margin: 1.5rem 0 0;
		text-align: center;
	}

	.mistakes {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.mistakes li {
		padding-left: 1rem;
		border-left: 3px solid var(--color-accent);
		font-size: 0.96875rem;
		color: color-mix(in srgb, var(--color-text) 78%, var(--color-background));
		line-height: 1.55;
	}

	.mistakes strong {
		color: var(--color-text);
	}

	.faq__list {
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.faq__item {
		padding-bottom: 1.5rem;
		border-bottom: 1px solid var(--color-border);
	}

	.faq__item:last-child {
		padding-bottom: 0;
		border-bottom: none;
	}

	.faq__q {
		margin: 0 0 0.5rem;
		font-size: 1.0625rem;
		font-weight: 650;
		color: var(--color-text);
	}

	.faq__a {
		margin: 0;
		font-size: 0.96875rem;
		line-height: 1.6;
		color: color-mix(in srgb, var(--color-text) 76%, var(--color-background));
	}
</style>
