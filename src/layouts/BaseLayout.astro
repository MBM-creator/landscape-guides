---
import type { SiteConfig } from '../config/sites';

interface Props {
	title: string;
	description: string;
	site: SiteConfig;
	canonical: string;
}

const { title, description, site, canonical } = Astro.props;
const ogUrl = canonical;

const GA_MEASUREMENT_ID = 'G-5PJ2TP2PN0';
const enableGoogleAnalytics = import.meta.env.PROD;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonical} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={ogUrl} />
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={site.name} />
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		{
			enableGoogleAnalytics && (
				<script
					async
					src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}
				></script>
			)
		}
		{
			enableGoogleAnalytics && (
				<script is:inline define:vars={{ measurementId: GA_MEASUREMENT_ID }}>
					window.dataLayer = window.dataLayer || [];
					function gtag() {
						dataLayer.push(arguments);
					}
					gtag('js', new Date());
					gtag('config', measurementId);
				</script>
			)
		}
	</head>
	<body>
		<slot />
		<script>
			import Clarity from '@microsoft/clarity';

			const projectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID ?? 'wq5xyynrrs';
			if (import.meta.env.PROD && projectId) {
				Clarity.init(projectId);
			}
		</script>
	</body>
</html>

<style is:global>
	:root {
		--color-text: #1f1f1f;
		--color-background: #f5f4f2;
		--color-primary: #7a9a8b;
		--color-primary-dark: #5f7f73;
		--color-accent: #c9d8d0;
		--color-white: #ffffff;
		--color-border: #e5e3df;
	}

	html {
		box-sizing: border-box;
		-webkit-text-size-adjust: 100%;
	}

	*,
	*::before,
	*::after {
		box-sizing: inherit;
	}

	body {
		margin: 0;
		min-height: 100%;
		font-family:
			system-ui,
			-apple-system,
			'Segoe UI',
			Roboto,
			'Helvetica Neue',
			Arial,
			sans-serif;
		color: var(--color-text);
		background-color: var(--color-background);
		line-height: 1.5;
	}

	/* Single-image hero bands (see `.media-section__inner`). Duo/compare layouts use their own frames. */
	section.media-section {
		padding: 0 clamp(1.25rem, 5vw, 3rem) clamp(2rem, 5.5vw, 3rem);
		background-color: var(--color-background);
	}

	section.media-section .media-section__inner {
		max-width: 56rem;
		margin: 0 auto;
		border-radius: 10px;
		overflow: hidden;
		border: 1px solid var(--color-border);
		background-color: var(--color-accent);
		box-shadow: 0 1px 0 color-mix(in srgb, var(--color-text) 6%, transparent);
	}

	section.media-section .media-section__inner > .media-section__img {
		display: block;
		width: 100%;
		height: auto;
		vertical-align: middle;
	}

	section.media-section.media-section--compact {
		padding-bottom: clamp(1.35rem, 3.5vw, 2.25rem);
	}

	section.media-section.media-section--compact .media-section__inner {
		max-height: min(34vw, 13.75rem);
		aspect-ratio: 2.35 / 1;
	}

	section.media-section.media-section--compact .media-section__inner > .media-section__img {
		height: 100%;
		object-fit: cover;
		object-position: center;
	}
</style>
